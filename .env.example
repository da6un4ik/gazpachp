# Required
AI_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx

# Provider: "huggingface" or "generic"
AI_PROVIDER=huggingface

# Optional for Hugging Face (default is router endpoint below)
AI_API_URL=https://router.huggingface.co/v1/chat/completions
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Optional TheMealDB key (default test key is 1)
THEMEALDB_API_KEY=1
